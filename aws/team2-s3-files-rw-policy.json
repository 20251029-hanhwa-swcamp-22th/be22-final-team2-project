{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadWriteOnFilesBucket",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload"
      ],
      "Resource": "arn:aws:s3:::team2-files-prod/*"
    },
    {
      "Sid": "ListFilesBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::team2-files-prod"
    }
  ]
}
