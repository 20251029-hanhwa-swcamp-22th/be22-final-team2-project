{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PutBackupObjects",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:AbortMultipartUpload"
      ],
      "Resource": "arn:aws:s3:::team2-db-backup-prod/*"
    },
    {
      "Sid": "ListOwnUploads",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::team2-db-backup-prod"
    }
  ]
}
